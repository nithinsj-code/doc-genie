# Copy this file to .env for local development.
# On Render, set these as Environment Variables in the dashboard instead.

GEMINI_API=your_gemini_api_key_here

# Comma-separated list of frontend origins allowed to call this API.
# Use * for local testing, but set it to your real Netlify URL in production.
ALLOWED_ORIGINS=https://your-site.netlify.app,http://localhost:5500
